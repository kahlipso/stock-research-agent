# PostgreSQL connection used by Prisma. Never commit the real value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# "mock" provides deterministic fixtures; "yahoo" enables unofficial delayed market data.
MARKET_DATA_PROVIDER="yahoo npm.cmd run ingest:prices"
MARKET_DATA_API_KEY=""
SEC_USER_AGENT="ggl20172017@outlook.com"
INGESTION_SECRET=""
APP_TIMEZONE="America/Los_Angeles"
ACTIVE_FACTOR_MODEL="MULTIFACTOR_V0"
ALLOW_MOCK_DATA="true"
