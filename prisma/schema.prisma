generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WatchlistStatus {
  RESEARCHING
  WATCHING
  READY_TO_BUY
  OWNED
  AVOID
}

enum PeriodType {
  ANNUAL
  QUARTERLY
}

enum MarketStatus {
  PRE_MARKET
  OPEN
  AFTER_HOURS
  CLOSED
  UNKNOWN
}

model Company {
  id                  String                      @id @default(cuid())
  ticker              String                      @unique
  name                String
  sector              String
  industry            String
  description         String                      @db.Text
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  watchlistItem       WatchlistItem?
  marketSnapshots     MarketSnapshot[]
  financialPeriods    FinancialPeriod[]
  valuationSnapshots  ValuationSnapshot[]
  researchScores      ResearchScore[]
  exchange            String?
  country             String?
  currency            String?
  securityType        String?
  cik                 String?
  active              Boolean                     @default(true)
  delistedAt          DateTime?
  universeMemberships UniverseMembership[]
  priceBars           PriceBar[]
  corporateActions    CorporateAction[]
  filings             Filing[]
  financialFacts      FinancialFact[]
  featureSnapshots    FeatureSnapshot[]
  normalizedFeatures  NormalizedFeatureSnapshot[]
  factorScores        FactorScoreSnapshot[]
  riskSnapshots       RiskMetricSnapshot[]
  liquiditySnapshots  LiquiditySnapshot[]
  analyses            AnalysisRecord[]
  modelRunsFailed     ModelCalculationFailure[]

  @@index([sector])
  @@index([industry])
}

model WatchlistItem {
  id            String          @id @default(cuid())
  companyId     String          @unique
  addedAt       DateTime        @default(now())
  personalNotes String?         @db.Text
  targetPrice   Decimal?        @db.Decimal(18, 4)
  status        WatchlistStatus @default(RESEARCHING)
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model MarketSnapshot {
  id                         String       @id @default(cuid())
  companyId                  String
  timestamp                  DateTime
  price                      Decimal?     @db.Decimal(18, 4)
  previousClose              Decimal?     @db.Decimal(18, 4)
  currentPrice               Decimal?     @db.Decimal(18, 4)
  dailyChangeAmount          Decimal?     @db.Decimal(18, 4)
  dailyChangePercent         Decimal?     @db.Decimal(12, 8)
  marketStatus               MarketStatus @default(UNKNOWN)
  priceTimestamp             DateTime
  marketCap                  Decimal?     @db.Decimal(24, 2)
  volume                     BigInt?
  fiftyTwoWeekHigh           Decimal?     @db.Decimal(18, 4)
  fiftyTwoWeekLow            Decimal?     @db.Decimal(18, 4)
  fiftyDayMovingAverage      Decimal?     @db.Decimal(18, 4)
  twoHundredDayMovingAverage Decimal?     @db.Decimal(18, 4)
  provider                   String?
  sourceIdentifier           String?
  retrievedAt                DateTime?
  effectiveAt                DateTime?
  isMock                     Boolean      @default(false)
  company                    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, timestamp])
}

model FinancialPeriod {
  id                String     @id @default(cuid())
  companyId         String
  periodEnd         DateTime
  periodType        PeriodType
  revenue           Decimal?   @db.Decimal(24, 2)
  operatingIncome   Decimal?   @db.Decimal(24, 2)
  netIncome         Decimal?   @db.Decimal(24, 2)
  freeCashFlow      Decimal?   @db.Decimal(24, 2)
  cash              Decimal?   @db.Decimal(24, 2)
  debt              Decimal?   @db.Decimal(24, 2)
  sharesOutstanding Decimal?   @db.Decimal(24, 2)
  grossMargin       Decimal?   @db.Decimal(12, 8)
  operatingMargin   Decimal?   @db.Decimal(12, 8)
  netMargin         Decimal?   @db.Decimal(12, 8)
  source            String
  retrievedAt       DateTime
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodEnd, periodType])
}

model ValuationSnapshot {
  id                  String   @id @default(cuid())
  companyId           String
  timestamp           DateTime
  trailingPE          Decimal? @db.Decimal(18, 4)
  forwardPE           Decimal? @db.Decimal(18, 4)
  priceToSales        Decimal? @db.Decimal(18, 4)
  priceToFreeCashFlow Decimal? @db.Decimal(18, 4)
  evToEbitda          Decimal? @db.Decimal(18, 4)
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, timestamp])
}

model ResearchScore {
  id                    String   @id @default(cuid())
  companyId             String
  calculatedAt          DateTime @default(now())
  growthScore           Decimal  @db.Decimal(6, 2)
  profitabilityScore    Decimal  @db.Decimal(6, 2)
  balanceSheetScore     Decimal  @db.Decimal(6, 2)
  valuationScore        Decimal  @db.Decimal(6, 2)
  momentumScore         Decimal  @db.Decimal(6, 2)
  dataCompletenessScore Decimal  @db.Decimal(6, 2)
  totalScore            Decimal  @db.Decimal(6, 2)
  explanation           Json
  isMock                Boolean  @default(true)
  legacy                Boolean  @default(true)
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, calculatedAt])
}

model InvestmentUniverse {
  id          String               @id @default(cuid())
  name        String               @unique
  description String?
  modelKey    String?
  active      Boolean              @default(true)
  ruleVersion String
  rules       Json
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  memberships UniverseMembership[]
}

model UniverseMembership {
  id            String             @id @default(cuid())
  universeId    String
  companyId     String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  source        String
  retrievedAt   DateTime
  universe      InvestmentUniverse @relation(fields: [universeId], references: [id], onDelete: Cascade)
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([universeId, companyId, effectiveFrom])
  @@index([universeId, effectiveFrom, effectiveTo])
}

model PriceBar {
  id               String    @id @default(cuid())
  companyId        String
  timestamp        DateTime
  interval         String
  open             Decimal   @db.Decimal(20, 6)
  high             Decimal   @db.Decimal(20, 6)
  low              Decimal   @db.Decimal(20, 6)
  close            Decimal   @db.Decimal(20, 6)
  adjustedClose    Decimal?  @db.Decimal(20, 6)
  volume           BigInt?
  provider         String
  sourceIdentifier String?
  retrievedAt      DateTime
  effectiveAt      DateTime?
  isMock           Boolean   @default(false)
  rawResponse      Json?
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, timestamp, interval, provider])
  @@index([companyId, timestamp])
}

model CorporateAction {
  id               String    @id @default(cuid())
  companyId        String
  actionType       String
  effectiveDate    DateTime
  ratio            Decimal?  @db.Decimal(20, 8)
  cashAmount       Decimal?  @db.Decimal(20, 6)
  provider         String
  sourceIdentifier String?
  retrievedAt      DateTime
  publishedAt      DateTime?
  isMock           Boolean   @default(false)
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, actionType, effectiveDate, provider])
  @@index([companyId, effectiveDate])
}

model Filing {
  id              String          @id @default(cuid())
  companyId       String
  accessionNumber String          @unique
  formType        String
  filingDate      DateTime
  periodEnd       DateTime?
  acceptedAt      DateTime?
  sourceUrl       String?
  provider        String
  retrievedAt     DateTime
  isMock          Boolean         @default(false)
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  facts           FinancialFact[]

  @@index([companyId, filingDate])
}

model FinancialFact {
  id               String    @id @default(cuid())
  companyId        String
  filingId         String?
  metricKey        String
  value            Decimal   @db.Decimal(30, 8)
  unit             String
  periodStart      DateTime?
  periodEnd        DateTime
  publishedAt      DateTime
  fiscalYear       Int?
  fiscalQuarter    String?
  periodType       String
  provider         String
  sourceIdentifier String?
  retrievedAt      DateTime
  isRestated       Boolean   @default(false)
  isMock           Boolean   @default(false)
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  filing           Filing?   @relation(fields: [filingId], references: [id])

  @@unique([companyId, metricKey, periodEnd, publishedAt, provider])
  @@index([companyId, metricKey, periodEnd])
  @@index([publishedAt])
}

model FeatureSnapshot {
  id           String    @id @default(cuid())
  companyId    String
  asOfDate     DateTime
  featureKey   String
  value        Decimal?  @db.Decimal(30, 10)
  modelVersion String
  formulaVersion String  @default("1.0.0")
  calculatedAt DateTime
  sourceAsOf   DateTime?
  sourceAvailableAt DateTime?
  provider     String?
  confidence   Decimal?  @db.Decimal(6, 4)
  nullReason   String?
  warnings     Json?
  metadata     Json?
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, asOfDate, featureKey, modelVersion])
  @@index([featureKey, asOfDate])
}

model NormalizedFeatureSnapshot {
  id              String   @id @default(cuid())
  companyId       String
  asOfDate        DateTime
  featureKey      String
  modelVersion    String
  normalizationVersion String @default("PERCENTILE_2_5_97_5_V1")
  rawValue        Decimal  @db.Decimal(30, 10)
  winsorizedValue Decimal  @db.Decimal(30, 10)
  normalizedValue Decimal  @db.Decimal(18, 10)
  percentileRank  Decimal  @db.Decimal(8, 6)
  peerGroupType   String
  peerGroupValue  String?
  peerGroupSize   Int
  direction       String
  calculatedAt    DateTime
  metadata        Json?
  warnings        Json?
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, asOfDate, featureKey, modelVersion])
  @@index([featureKey, asOfDate])
}

model FactorModelVersion {
  id            String                @id @default(cuid())
  modelKey      String
  version       String
  name          String
  horizon       String
  weights       Json
  configuration Json
  active        Boolean               @default(false)
  createdAt     DateTime              @default(now())
  scores        FactorScoreSnapshot[]
  calculationRuns ModelCalculationRun[]

  @@unique([modelKey, version])
}

model FactorScoreSnapshot {
  id                   String             @id @default(cuid())
  companyId            String
  asOfDate             DateTime
  modelVersionId       String
  modelCalculationRunId String?
  universeRuleVersion  String
  qualityScore         Decimal?           @db.Decimal(8, 4)
  valueScore           Decimal?           @db.Decimal(8, 4)
  growthScore          Decimal?           @db.Decimal(8, 4)
  revisionScore        Decimal?           @db.Decimal(8, 4)
  momentumScore        Decimal?           @db.Decimal(8, 4)
  alphaScore           Decimal?           @db.Decimal(8, 4)
  confidenceScore      Decimal?           @db.Decimal(8, 4)
  riskScore            Decimal?           @db.Decimal(8, 4)
  liquidityScore       Decimal?           @db.Decimal(8, 4)
  universePercentile   Decimal?           @db.Decimal(8, 6)
  industryPercentile   Decimal?           @db.Decimal(8, 6)
  sectorPercentile     Decimal?           @db.Decimal(8, 6)
  candidateBand        String
  calculatedAt         DateTime
  dataAsOf             DateTime
  priceAsOf            DateTime?
  currentUniverseRank  Int?
  currentSectorRank    Int?
  currentIndustryRank  Int?
  alphaChange1d        Decimal? @db.Decimal(8, 4)
  alphaChange7d        Decimal? @db.Decimal(8, 4)
  alphaChange30d       Decimal? @db.Decimal(8, 4)
  rankChange1d         Int?
  rankChange30d        Int?
  featureContributions Json
  factorContributions  Json
  effectiveWeights     Json
  warnings             Json?
  isMock               Boolean            @default(false)
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  modelVersion         FactorModelVersion @relation(fields: [modelVersionId], references: [id])
  modelCalculationRun  ModelCalculationRun? @relation(fields: [modelCalculationRunId], references: [id])

  @@unique([companyId, asOfDate, modelVersionId])
  @@index([asOfDate, alphaScore])
  @@index([modelCalculationRunId])
}

model RiskMetricSnapshot {
  id                 String   @id @default(cuid())
  companyId          String
  asOfDate           DateTime
  modelVersion       String
  volatility20d      Decimal? @db.Decimal(18, 10)
  volatility60d      Decimal? @db.Decimal(18, 10)
  volatility252d     Decimal? @db.Decimal(18, 10)
  downsideVolatility Decimal? @db.Decimal(18, 10)
  betaSpy            Decimal? @db.Decimal(18, 10)
  maximumDrawdown    Decimal? @db.Decimal(18, 10)
  maximumDrawdown3y  Decimal? @db.Decimal(18, 10)
  atrPercent         Decimal? @db.Decimal(18, 10)
  gapRisk            Decimal? @db.Decimal(18, 10)
  largestOneDayGap   Decimal? @db.Decimal(18, 10)
  recentGapFrequency Decimal? @db.Decimal(18, 10)
  idiosyncraticVolatility Decimal? @db.Decimal(18, 10)
  correlationSpy     Decimal? @db.Decimal(18, 10)
  missingBarPercent  Decimal? @db.Decimal(18, 10)
  riskScore          Decimal? @db.Decimal(8, 4)
  classification     String
  calculatedAt       DateTime
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, asOfDate, modelVersion])
}

model LiquiditySnapshot {
  id                       String   @id @default(cuid())
  companyId                String
  asOfDate                 DateTime
  medianDollarVolume       Decimal? @db.Decimal(30, 4)
  averageDailyVolume       Decimal? @db.Decimal(30, 4)
  averageDollarVolume      Decimal? @db.Decimal(30, 4)
  medianShareVolume        Decimal? @db.Decimal(30, 4)
  estimatedDaysToLiquidate Decimal? @db.Decimal(18, 8)
  price                    Decimal? @db.Decimal(20, 6)
  tradingHistoryDays       Int
  missingBarCount          Int
  liquidityScore           Decimal? @db.Decimal(8, 4)
  classification           String
  calculatedAt             DateTime
  company                  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, asOfDate])
}

model ModelCalculationRun {
  id                  String   @id @default(cuid())
  modelVersionId      String
  asOfDate            DateTime
  universeId          String
  status              String
  startedAt           DateTime
  completedAt         DateTime?
  securitiesEligible  Int      @default(0)
  securitiesScored    Int      @default(0)
  securitiesFailed    Int      @default(0)
  errorSummary        String?
  metadata            Json?
  modelVersion        FactorModelVersion @relation(fields: [modelVersionId], references: [id])
  failures            ModelCalculationFailure[]
  scores              FactorScoreSnapshot[]
  @@index([asOfDate, status])
  @@index([modelVersionId, asOfDate])
}

model ModelCalculationFailure {
  id          String @id @default(cuid())
  runId       String
  companyId   String
  stage       String
  message     String
  createdAt   DateTime @default(now())
  run         ModelCalculationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@index([runId])
}

model DataIngestionRun {
  id             String    @id @default(cuid())
  jobType        String
  provider       String
  startedAt      DateTime
  completedAt    DateTime?
  status         String
  recordsRead    Int       @default(0)
  recordsWritten Int       @default(0)
  recordsFailed  Int       @default(0)
  errorSummary   String?
  metadata       Json?

  @@index([jobType, startedAt])
}

model AnalysisRecord {
  id          String    @id @default(cuid())
  companyId   String
  summary     String    @db.Text
  provider    String
  model       String?
  generatedAt DateTime
  dataAsOf    DateTime
  staleAt     DateTime?
  metadata    Json?
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, generatedAt])
}
